{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@spartan-ng/helm/sidebar": [
        "./src/app/shared/ui/spartan/sidebar/src/index.ts"
      ],
      "@spartan-ng/helm/utils": [
        "./src/app/shared/ui/spartan/utils/src/index.ts"
      ],
      "@spartan-ng/helm/button": [
        "./src/app/shared/ui/spartan/button/src/index.ts"
      ],
      "@spartan-ng/helm/icon": [
        "./src/app/shared/ui/spartan/icon/src/index.ts"
      ],
      "@spartan-ng/helm/input": [
        "./src/app/shared/ui/spartan/input/src/index.ts"
      ],
      "@spartan-ng/helm/separator": [
        "./src/app/shared/ui/spartan/separator/src/index.ts"
      ],
      "@spartan-ng/helm/sheet": [
        "./src/app/shared/ui/spartan/sheet/src/index.ts"
      ],
      "@spartan-ng/helm/skeleton": [
        "./src/app/shared/ui/spartan/skeleton/src/index.ts"
      ],
      "@spartan-ng/helm/tooltip": [
        "./src/app/shared/ui/spartan/tooltip/src/index.ts"
      ],
      "@spartan-ng/helm/collapsible": [
        "./src/app/shared/ui/spartan/collapsible/src/index.ts"
      ],
      "@spartan-ng/helm/alert": [
        "./src/app/shared/ui/spartan/alert/src/index.ts"
      ],
      "@spartan-ng/helm/card": [
        "./src/app/shared/ui/spartan/card/src/index.ts"
      ],
      "@spartan-ng/helm/label": [
        "./src/app/shared/ui/spartan/label/src/index.ts"
      ]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
